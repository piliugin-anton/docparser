# HuggingFace token (optional for public repos)
# HF_TOKEN=

# API server
BIND_ADDR=0.0.0.0:8080
MODELS_DIR=models
MAX_UPLOAD_MB=20
MAX_TOKENS=4096

# Candle inference backend: cpu | cuda | metal | wgpu | auto
# GPU backends require matching cargo feature, e.g.:
#   cargo run -p docparser-api --features cuda
# Omit BACKEND to use auto (GPU build) or cpu (CPU-only build). Set cpu to force CPU.
BACKEND=auto
# CUDA_DEVICE=0
# METAL_DEVICE=0

# Pipeline (PaddleOCR-VL v1.6 defaults; doc prep enabled)
# USE_DOC_ORIENTATION_CLASSIFY=true
# USE_DOC_UNWARPING=true
# LAYOUT_UNCLIP_RATIO=1.0
# CROP_PADDING_RATIO=0.0
# LAYOUT_THRESHOLD=0.3
# LAYOUT_NMS=true
# MERGE_LAYOUT_BLOCKS=true

# Logging
RUST_LOG=info,docparser_api=info

# Slow parity tests (requires downloaded models)
# RUN_SLOW=1
