# HuggingFace token (optional for public repos)
# HF_TOKEN=

# API server
BIND_ADDR=0.0.0.0:8080
MODELS_DIR=models
MAX_UPLOAD_MB=20
MAX_TOKENS=4096

# Pipeline profile: minimal (default) or official_v16
# PIPELINE_PROFILE=official_v16
# LAYOUT_UNCLIP_RATIO=1.0
# LAYOUT_THRESHOLD=0.5
# LAYOUT_NMS=false
# MERGE_LAYOUT_BLOCKS=true

# Logging
RUST_LOG=info,docparser_api=info

# Slow parity tests (requires downloaded models)
# RUN_SLOW=1
